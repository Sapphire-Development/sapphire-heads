---
import Layout from "../layouts/Layout.astro";
import HeadsGrid from "../components/HeadsGrid.astro";
---

<Layout>
	<main class="container mx-auto px-4 pb-12">
		<div class="py-12 text-center space-y-4">
			<div class="flex justify-center mb-4">
				<img
					src="/sapphirewhite.png"
					alt="Sapphire Heads Logo"
					class="h-24 w-24 object-contain"
				/>
			</div>
			<h1 class="text-4xl font-extrabold tracking-tight lg:text-5xl">
				Sapphire Heads
			</h1>
			<p class="text-lg text-muted-foreground max-w-2xl mx-auto">
				Browse and discover thousands of Minecraft heads. Search by
				name, tag, or category to find the perfect decoration for your
				world.
			</p>
		</div>

		<HeadsGrid />
	</main>
</Layout>
