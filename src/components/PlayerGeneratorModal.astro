---
import { X, Search, Loader2 } from "@lucide/astro";
import Button from "./ui/Button.astro";
import Input from "./ui/Input.astro";
---

<dialog
    id="player-generator-modal"
    class="backdrop:backdrop-blur-sm bg-transparent p-0 m-auto max-w-md w-full open:animate-in open:fade-in-0 open:zoom-in-95 closed:animate-out closed:fade-out-0 closed:zoom-out-95"
>
    <div
        class="relative grid gap-6 rounded-lg border bg-background text-foreground p-6 shadow-lg"
    >
        <button
            id="close-generator-modal"
            class="absolute right-4 top-4 rounded-sm opacity-70 transition-opacity hover:opacity-100 focus:outline-none focus:ring-2 focus:ring-ring disabled:pointer-events-none data-[state=open]:bg-accent data-[state=open]:text-muted-foreground text-foreground"
        >
            <X class="h-4 w-4" />
            <span class="sr-only">Close</span>
        </button>

        <div class="flex flex-col space-y-1.5 text-center sm:text-left">
            <h2 class="text-lg font-semibold leading-none tracking-tight">
                Get Player Head
            </h2>
            <p class="text-sm text-muted-foreground">
                Enter a Minecraft username to generate their head data.
            </p>
        </div>

        <div class="grid gap-4 py-4">
            <div class="grid gap-2">
                <label
                    for="username-input"
                    class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70"
                >
                    Username
                </label>
                <div class="flex gap-2">
                    <Input
                        id="username-input"
                        placeholder="Notch"
                        class="col-span-3"
                    />
                </div>
            </div>
            <p
                id="generator-error"
                class="text-[0.8rem] font-medium text-destructive hidden"
            >
            </p>
        </div>

        <div class="flex justify-end gap-2">
            <Button variant="outline" id="cancel-generator-btn">Cancel</Button>
            <Button id="generate-btn" disabled>
                <span id="generate-text">Generate</span>
                <Loader2
                    id="generate-loader"
                    class="ml-2 h-4 w-4 animate-spin hidden"
                />
            </Button>
        </div>
    </div>
</dialog>

<script>
    import type { Head } from "../types";

    const modal = document.getElementById(
        "player-generator-modal",
    ) as HTMLDialogElement;
    const closeBtn = document.getElementById("close-generator-modal");
    const cancelBtn = document.getElementById("cancel-generator-btn");
    const generateBtn = document.getElementById(
        "generate-btn",
    ) as HTMLButtonElement;
    const input = document.getElementById("username-input") as HTMLInputElement;
    const errorMsg = document.getElementById("generator-error");
    const loader = document.getElementById("generate-loader");
    const btnText = document.getElementById("generate-text");

    // Open/Close Logic
    document.addEventListener("open-player-generator", () => {
        input.value = "";
        errorMsg?.classList.add("hidden");
        generateBtn.disabled = true;
        modal.showModal();
        input.focus();
    });

    function closeModal() {
        modal.close();
    }

    closeBtn?.addEventListener("click", closeModal);
    cancelBtn?.addEventListener("click", closeModal);

    // Close on backdrop click
    modal?.addEventListener("click", (e) => {
        const rect = modal.getBoundingClientRect();
        const isInDialog =
            rect.top <= e.clientY &&
            e.clientY <= rect.top + rect.height &&
            rect.left <= e.clientX &&
            e.clientX <= rect.left + rect.width;
        if (!isInDialog) {
            modal.close();
        }
    });

    // Input Validation
    input?.addEventListener("input", () => {
        generateBtn.disabled = input.value.trim().length === 0;
        errorMsg?.classList.add("hidden");
    });

    input?.addEventListener("keypress", (e) => {
        if (e.key === "Enter" && !generateBtn.disabled) {
            generateHead();
        }
    });

    generateBtn?.addEventListener("click", generateHead);

    async function generateHead() {
        const username = input.value.trim();
        if (!username) return;

        // Loading State
        generateBtn.disabled = true;
        loader?.classList.remove("hidden");
        if (btnText) btnText.textContent = "Generating...";
        errorMsg?.classList.add("hidden");

        try {
            // 1. Fetch from PlayerDB
            const res = await fetch(
                `https://playerdb.co/api/player/minecraft/${username}`,
            );
            if (!res.ok) throw new Error("Player not found");

            const data = await res.json();

            if (!data.success || !data.data || !data.data.player) {
                throw new Error("Invalid response from API");
            }

            // 2. Decode Skin Data
            // Structure: data.data.player.properties is array of {name: "textures", value: "BASE64..."}
            const properties = data.data.player.properties;
            const textureProp = properties.find(
                (p: any) => p.name === "textures",
            );

            if (!textureProp || !textureProp.value) {
                throw new Error("No skin data found for this player");
            }

            const decodedValue = atob(textureProp.value);
            const skinJson = JSON.parse(decodedValue);

            // 3. Extract Texture ID
            // Structure: { textures: { SKIN: { url: "http://textures.minecraft.net/texture/ID" } } }
            const skinUrl = skinJson.textures?.SKIN?.url;
            if (!skinUrl) throw new Error("No skin URL found");

            const textureId = skinUrl.split("/").pop();

            if (!textureId) throw new Error("Could not parse texture ID");

            // 4. Dispatch Event
            const head: Head = {
                id: 0, // Dummy ID
                name: data.data.player.username, // Use correct casing from API
                category: "Player",
                tags: ["Player", "Custom"],
                texture: textureId,
            };

            document.dispatchEvent(
                new CustomEvent("open-head-modal", { detail: head }),
            );

            closeModal();
        } catch (e) {
            if (errorMsg) {
                errorMsg.textContent =
                    e instanceof Error ? e.message : "Failed to generate head";
                errorMsg.classList.remove("hidden");
            }
        } finally {
            // Reset Loading State
            generateBtn.disabled = false;
            loader?.classList.add("hidden");
            if (btnText) btnText.textContent = "Generate";
            // Keep input focus if error so user can retry
            if (!errorMsg?.classList.contains("hidden")) {
                input.focus();
            }
        }
    }
</script>

<style>
    dialog {
        transition:
            opacity 0.2s ease-out,
            transform 0.2s ease-out;
        opacity: 0;
        transform: scale(0.95);
    }

    dialog[open] {
        opacity: 1;
        transform: scale(1);
        @starting-style {
            opacity: 0;
            transform: scale(0.95);
        }
    }

    dialog::backdrop {
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
        transition:
            opacity 0.2s ease-out,
            backdrop-filter 0.2s ease-out;
        opacity: 0;
    }

    dialog[open]::backdrop {
        opacity: 1;
        @starting-style {
            opacity: 0;
        }
    }
</style>
