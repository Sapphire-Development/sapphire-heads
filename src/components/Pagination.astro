---
import Button from "./ui/Button.astro";
import {
    ChevronLeft,
    ChevronRight,
    ChevronsLeft,
    ChevronsRight,
} from "@lucide/astro";

interface Props {
    id?: string;
    class?: string;
}

const { id, class: className } = Astro.props;
---

<div id={id} class:list={["flex items-center justify-center gap-2", className]}>
    <Button variant="outline" size="icon" class="pagination-first" disabled>
        <ChevronsLeft class="h-4 w-4" />
        <span class="sr-only">First page</span>
    </Button>

    <Button variant="outline" size="icon" class="pagination-prev" disabled>
        <ChevronLeft class="h-4 w-4" />
        <span class="sr-only">Previous page</span>
    </Button>

    <div class="flex items-center gap-1 mx-2 text-sm font-medium">
        Page <span class="pagination-current">1</span> of <span
            class="pagination-total">...</span
        >
    </div>

    <Button variant="outline" size="icon" class="pagination-next" disabled>
        <ChevronRight class="h-4 w-4" />
        <span class="sr-only">Next page</span>
    </Button>

    <Button variant="outline" size="icon" class="pagination-last" disabled>
        <ChevronsRight class="h-4 w-4" />
        <span class="sr-only">Last page</span>
    </Button>
</div>
